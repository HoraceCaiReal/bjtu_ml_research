    "plt.ylim(0, 1.05)\n",
    "plt.legend(loc="lower right")\n",
    "plt.grid(axis="y", alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-24",
   "metadata": {},
   "source": [
    "## 5. 超参数调优探索\n",
    "\n",
    "对效果较好的分类器进行关键超参数调优，观察参数变化对性能的影响。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-25",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5.1 决策树：max_depth 探索\n",
    "from sklearn.metrics import f1_score\n",
    "\n",
    "depths = list(range(1, 31, 2))\n",
    "dt_val_f1 = []\n",
    "dt_train_f1 = []\n",
    "\n",
    "for depth in tqdm(depths, desc="决策树 max_depth"):\n",
    "    model = TraditionalClassifier(model_type="decision_tree", max_depth=depth, random_state=42)\n",
    "    model.fit(X_train, y_train)\n",
    "    dt_train_f1.append(f1_score(y_train, model.predict(X_train), zero_division=0))\n",
    "    dt_val_f1.append(f1_score(y_val, model.predict(X_val), zero_division=0))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "ax.plot(depths, dt_train_f1, "o-", color="#4e79a7", label="训练集 F1")\n",
    "ax.plot(depths, dt_val_f1, "s-", color="#f28e2b", label="验证集 F1")\n",
    "ax.set_xlabel("max_depth")\n",
    "ax.set_ylabel("F1 分数")\n",
    "ax.set_title("决策树 max_depth 参数探索")\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "# 标记最优验证点\n",
    "best_idx = np.argmax(dt_val_f1)\n",
    "ax.annotate(\n",
    "    f"最优 depth={depths[best_idx]}, F1={dt_val_f1[best_idx]:.4f}",\n",
    "    xy=(depths[best_idx], dt_val_f1[best_idx]),\n",
    "    xytext=(depths[best_idx] + 5, dt_val_f1[best_idx] - 0.03),\n",
    "    arrowprops=dict(arrowstyle="->", color="red"),\n",
    "    fontsize=10,\n",
    "    color="red",\n",
    ")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-26",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5.2 KNN：n_neighbors 探索\n",
    "neighbors = list(range(1, 31, 2))\n",
    "knn_val_f1 = []\n",
    "knn_train_f1 = []\n",
    "\n",
    "for k in tqdm(neighbors, desc="KNN n_neighbors"):\n",
    "    model = TraditionalClassifier(model_type="knn", n_neighbors=k)\n",
    "    model.fit(X_train, y_train)\n",
    "    knn_train_f1.append(f1_score(y_train, model.predict(X_train), zero_division=0))\n",
    "    knn_val_f1.append(f1_score(y_val, model.predict(X_val), zero_division=0))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
