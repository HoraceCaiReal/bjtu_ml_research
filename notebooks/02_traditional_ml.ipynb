    "for c_val in tqdm(svm_c_values, desc="SVM C 参数"):\n",
    "    model = TraditionalClassifier(\n",
    "        model_type="svm", kernel="rbf", C=c_val, probability=True, random_state=42\n",
    "    )\n",
    "    model.fit(X_train, y_train)\n",
    "    svm_train_f1.append(f1_score(y_train, model.predict(X_train), zero_division=0))\n",
    "    svm_val_f1.append(f1_score(y_val, model.predict(X_val), zero_division=0))\n",
