    "# 5.3 SVM：C 正则化参数探索\n",
    "svm_c_values = [0.01, 0.1, 0.5, 1.0, 2.0, 5.0, 10.0]\n",
    "svm_val_f1 = []\n",
    "svm_train_f1 = []\n",
