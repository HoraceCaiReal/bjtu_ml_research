# 数据保密：绝不上传数据集
data/*
!data/README.md
!data/.gitkeep
*.jpg
*.jpeg
*.png
*.zip
*.tar.gz

# 模型权重文件（通常较大，若需共享可用 Git LFS，但建议忽略）
# 注意：仅忽略根目录的 models/ 权重文件夹，不忽略 src/models/ 源代码
/models/
*.pth
*.h5
*.pkl
*.joblib

# Jupyter 临时文件
.ipynb_checkpoints/
*.ipynb_checkpoints
*.nbconvert.ipynb

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# VS Code 个人设置（保留共享设置）
# .vscode/settings.json 是团队共享配置（字体、格式化等），故意保留
# .vscode/extensions.json 是团队共享推荐插件，故意保留
# 仅忽略个人本地历史/调试配置
.vscode/launch.json
.vscode/tasks.json

# 虚拟环境 / Conda
.env
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Conda 环境文件（个人本地配置不上传）
# environment.yml 是团队共享的，不忽略
# 但如果生成 environment.lock.yml 可以忽略
*.lock.yml

# 操作系统文件
.DS_Store
Thumbs.db

# 实验输出（由代码生成，不纳入版本控制）
# 使用 xxx/* 而非 xxx/ 以确保 .gitkeep 能被 Git 追踪
outputs/*
!outputs/.gitkeep
# 预训练模型和结果对比表【有意提交】（Gradio 可视化系统运行时依赖）
# 上方的 *.pth / *.joblib / *.h5 / *.pkl 全局忽略在此通过 ! 规则放行：
# outputs/models、scalers、results 下的权重与结果文件都纳入版本控制，
# 保证克隆后无需训练即可加载演示（数据集保密、不可复现训练的前提下）。
!outputs/models/
!outputs/scalers/
!outputs/results/
results/*
logs/*

# 提交物目录：保留目录结构，但忽略生成的大文件
# 报告由 notebooks 导出，视频单独提交
videos/*.mp4
videos/*.avi
videos/*.mov
# 但保留目录说明
!videos/.gitkeep
!reports/.gitkeep
!data/.gitkeep_backup/
_backup/
# scripts 目录：作为项目测试代码纳入版本控制，仅排除运行产物/缓存
scripts/__pycache__/
scripts/_nb_test/
scripts/test_result.txt

# PPT 演讲图表（演讲交付物，需纳入版本控制，覆盖上方 *.png 全局忽略）
!reports/ppt图表输出/*.png

# 报告生成缓存：特征矩阵体积巨大（300MB+），可由脚本重新生成，不纳入版本控制
commit_report/figures/features_cache.npz
