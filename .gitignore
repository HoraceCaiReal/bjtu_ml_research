# 数据保密：绝不上传数据集
data/*
!data/README.md
!data/.gitkeep
*.jpg
*.jpeg
*.png
*.zip
*.tar.gz

# 模型权重文件（通常较大，若需共享可用 Git LFS，但建议忽略）
models/
*.pth
*.h5
*.pkl
*.joblib

# Jupyter 临时文件
.ipynb_checkpoints/
*.ipynb_checkpoints
*.nbconvert.ipynb

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# VS Code 个人设置（保留共享设置）
# .vscode/settings.json 是团队共享配置（字体、格式化等），故意保留
# 仅忽略个人本地历史/调试配置
.vscode/extensions.json
.vscode/launch.json
.vscode/tasks.json

# 虚拟环境 / Conda
.env
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Conda 环境文件（个人本地配置不上传）
# environment.yml 是团队共享的，不忽略
# 但如果生成 environment.lock.yml 可以忽略
*.lock.yml

# 操作系统文件
.DS_Store
Thumbs.db

# 实验输出（由代码生成，不纳入版本控制）
outputs/
results/
logs/

# 提交物目录：保留目录结构，但忽略生成的大文件
# 报告由 notebooks 导出，视频单独提交
videos/*.mp4
videos/*.avi
videos/*.mov
# 但保留目录说明
!videos/.gitkeep
!reports/.gitkeep
!outputs/.gitkeep
!data/.gitkeep